{
  "description": "slopstop - blocks installs of hallucinated npm/PyPI packages, warns on suspicious newly-added manifest deps",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/check_install.py\"",
            "timeout": 15
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/check_manifest.py\"",
            "timeout": 15
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ]
  }
}
